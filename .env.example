# ─── Server ───────────────────────────────────────────────────
PORT=4321
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=playroom

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_something_long_and_random_in_production
JWT_EXPIRES_IN=7d

# ─── Frontend ─────────────────────────────────────────────────
# React dev server port — must match "start" script in package.json
FRONTEND_URL=http://localhost:3333
